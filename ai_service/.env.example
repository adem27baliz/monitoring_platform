# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC_METRICS=metrics
KAFKA_TOPIC_ANOMALIES=anomalies
KAFKA_GROUP_ID=ai-anomaly-detector

# Detection thresholds
AUTOENCODER_THRESHOLD=0.05
ISOLATION_FOREST_CONTAMINATION=0.05

# Training
MIN_SAMPLES_TO_TRAIN=100
RETRAIN_INTERVAL_SECONDS=1800
ROLLING_WINDOW_SIZE=5000

# Model persistence
MODEL_DIR=models/